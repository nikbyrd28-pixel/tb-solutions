    {
      "parameters": {
        "jsCode": "function items(name){ try { return $(name).all().filter(i => i.json && Object.keys(i.json).length); } catch(e){ return []; } }\nconst leads = items('Get new leads');\nconst tickets = items('Get open tickets');\nconst views = items('Get pageviews');\nconst urgent = tickets.filter(t => /urgent/i.test(t.json.priority || '')).length;\nconst lines = [];\nlines.push(`🔥 New leads this week: ${leads.length}`);\nlines.push(`🛟 Open requests: ${tickets.length}${urgent ? ` (⚠️ ${urgent} urgent)` : ''}`);\nlines.push(`👀 Website visits (7 days): ${views.length}${views.length >= 1000 ? '+' : ''}`);\nconst tip = leads.length === 0\n  ? 'No new leads this week — worth a round of outreach or a fresh post. Marketing Tools in your CRM has templates ready.'\n  : 'Leads are coming in — make sure every one gets a fast follow-up. Speed wins.';\nreturn [{ json: { report: lines.join('\\n'), tip } }];"
      },
      "id": "code1",
      "name": "Build report",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1140,
        300
      ]
    },
