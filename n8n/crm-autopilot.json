    {
      "parameters": {
        "method": "POST",
        "url": "https://qgbjiqdwzgkjkmqyjsmc.supabase.co/rest/v1/leads",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "apikey",
              "value": "PASTE_SERVICE_KEY"
            },
            {
              "name": "Authorization",
              "value": "Bearer PASTE_SERVICE_KEY"
            },
            {
              "name": "Prefer",
              "value": "return=minimal"
            }
          ]
        },
        "sendBody": true,
        "contentType": "json",
        "bodyParameters": {
          "parameters": [
            {
              "name": "id",
              "value": "={{ Date.now().toString(36) + Math.random().toString(36).slice(2,7) }}"
            },
            {
              "name": "name",
              "value": "={{ $json.body.name || '' }}"
            },
            {
              "name": "business",
              "value": "={{ $json.body.business || '' }}"
            },
            {
              "name": "phone",
              "value": "={{ $json.body.phone || '' }}"
            },
            {
              "name": "email",
              "value": "={{ $json.body.email || '' }}"
            },
            {
              "name": "stage",
              "value": "New"
            },
            {
              "name": "source",
              "value": "={{ $json.body.source || 'website' }}"
            },
            {
              "name": "followup",
              "value": "={{ new Date(Date.now() + 2*86400000).toISOString().slice(0,10) }}"
            },
            {
              "name": "note",
              "value": "={{ ('Wants: ' + ($json.body.interest || '—') + '. ' + ($json.body.message || '')).trim() }}"
            }
          ]
        },
        "options": {}
