    },
    {
      "parameters": {
        "promptType": "define",
        "text": "=You are the lead qualification assistant for VoomLux, a luxury black-SUV chauffeur service in Philadelphia (airport transfers, events, corporate, hourly).\n\nAnalyze this inbound lead:\n- Name: {{ $json.name }}\n- Email: {{ $json.email }}\n- Phone: {{ $json.phone }}\n- Service type: {{ $json.service_type }}\n- Pickup date: {{ $json.pickup_date }}\n- Pickup: {{ $json.pickup_location }}\n- Dropoff: {{ $json.dropoff_location }}\n- Party size: {{ $json.party_size }}\n- Message: {{ $json.message }}\n- Source: {{ $json.source }}\n\nScore it. High scores: near-term pickup dates, airport/corporate/event intent, complete contact info. Low: vague, spam, job-seeking.\nRespond with ONLY a valid JSON object, no markdown fences:\n{\n  \"lead_score\": <integer 0-100>,\n  \"intent\": <\"booking\" | \"quote\" | \"inquiry\" | \"partnership\" | \"spam\" | \"other\">,\n  \"priority\": <\"high\" | \"medium\" | \"low\">,\n  \"summary\": <one sentence>,\n  \"suggested_action\": <one sentence>\n}"
      },
      "id": "b1000000-0000-4000-8000-000000000004",
      "name": "AI Lead Scoring",
      "type": "@n8n/n8n-nodes-langchain.chainLlm",
      "typeVersion": 1.5,
      "position": [
        660,
        -100
      ]
    },
    {
      "parameters": {
        "modelName": "models/gemini-2.0-flash",
        "options": {}
      },
      "id": "b1000000-0000-4000-8000-000000000005",
      "name": "Anthropic Chat Model",
      "type": "@n8n/n8n-nodes-langchain.lmChatGoogleGemini",
      "typeVersion": 1,
      "position": [
        660,
        100
      ]
    },
    {
      "parameters": {
        "jsCode": "const lead = $('Validate & Normalize').first().json;\nlet ai = {};\ntry {\n  let t = $json.text || '';\n  t = t.replace(/```json|```/g, '').trim();\n  const m = t.match(/\\{[\\s\\S]*\\}/);\n  ai = m ? JSON.parse(m[0]) : {};\n} catch (e) { ai = {}; }\n\nreturn [{ json: {\n  ...lead,\n  lead_score: Number(ai.lead_score) || 0,\n  intent: ai.intent || 'unknown',\n  priority: ai.priority || 'low',\n  ai_summary: ai.summary || 'AI scoring failed — review manually',\n  suggested_action: ai.suggested_action || 'Manual review'\n} }];"
      },
