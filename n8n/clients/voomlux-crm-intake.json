    {
      "parameters": {
        "jsCode": "// Matches the fields tbsol.net/clients/voomlux posts: name, phone, email, service, pickup, dropoff, date, passengers, message, source\nconst body = $json.body || $json;\nconst clean = (s) => (typeof s === 'string' ? s.trim() : '');\n\nconst name = clean(body.name);\nconst email = clean(body.email).toLowerCase();\nconst phone = clean(body.phone);\n\nconst rawService = clean(body.service || body.service_type).toLowerCase();\nlet service_type = 'other';\nif (rawService.includes('airport')) service_type = 'airport';\nelse if (rawService.includes('corporate') || rawService.includes('executive')) service_type = 'corporate';\nelse if (rawService.includes('wedding') || rawService.includes('event') || rawService.includes('night out')) service_type = 'event';\nelse if (rawService.includes('hourly') || rawService.includes('as-directed')) service_type = 'hourly';\n\nconst ride_date_raw = clean(body.date || body.pickup_date);\nlet pickup_date = /^\\d{4}-\\d{2}-\\d{2}/.test(ride_date_raw) ? ride_date_raw.slice(0,10) : null;\nconst pickup_location = clean(body.pickup || body.pickup_location);\nconst dropoff_location = clean(body.dropoff || body.dropoff_location);\nconst party_size = Number(body.passengers || body.party_size) || null;\nlet message = clean(body.message);\nif (ride_date_raw && !pickup_date) message = (message ? message + ' | ' : '') + 'Requested date: ' + ride_date_raw;\nconst source = clean(body.source) || 'website';\n\nconst emailOk = /^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/.test(email);\nconst valid = (emailOk || phone.length >= 7) && (name.length > 0 || message.length > 0);\n\nreturn [{ json: { valid, name, email: emailOk ? email : null, phone, service_type, pickup_date, pickup_location, dropoff_location, party_size, message, source, received_at: new Date().toISOString(), next_followup_at: new Date(Date.now() + 24*60*60*1000).toISOString() } }];"
      },
      "id": "b1000000-0000-4000-8000-000000000002",
      "name": "Validate & Normalize",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        220,
        0
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
