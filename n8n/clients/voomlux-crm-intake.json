{
  "name": "VoomLux CRM — Lead Intake (webhook → AI score → CRM → auto-reply)",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "voomlux-leads",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "b1000000-0000-4000-8000-000000000001",
      "name": "Lead Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [
        0,
        0
      ],
      "webhookId": "voomlux-leads"
